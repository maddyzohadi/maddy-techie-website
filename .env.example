# ─── Supabase (waitlist) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── AI Assistant (OpenRouter) ───────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── Services contact form (Resend) ─────────────────────────────────────────
# Sign up at https://resend.com, create an API key, and verify your sending domain.
# FROM address must match a verified domain in your Resend account.
# During local dev you can set FROM to: onboarding@resend.dev
RESEND_API_KEY=
RESEND_FROM_EMAIL=Maddy the Techie <noreply@maddythetechie.com>

# ─── Starter Kit email delivery ──────────────────────────────────────────────
# Set STARTER_KIT_PROVIDER to the service you choose, then fill in the key/ID.
# Supported options (see app/api/starter-kit/route.ts for integration examples):
#   kit | mailchimp | resend | supabase
STARTER_KIT_PROVIDER=
STARTER_KIT_API_KEY=
STARTER_KIT_API_SECRET=
STARTER_KIT_FORM_ID=
